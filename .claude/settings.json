      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git rev-list:*)",
      "Bash(git shortlog:*)",
      "Bash(git ls-files:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git stash:*)",
      "Bash(git restore:*)",
      "Bash(git push:*)",
      "mcp__github",
      "mcp__Supabase",
      "mcp__Vercel",
      "mcp__Notion",
      "mcp__Bigdata_com",
      "mcp__Hugging_Face",
      "mcp__Granola",
      "mcp__Zoom_for_Claude",
      "mcp__Google_Drive",
      "mcp__Google_Calendar",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Bash(rm -rf /*)",
      "Bash(git push:* main)",
      "Bash(git push:* master)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-setup.sh\"" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-live.sh\"" }
        ]
      }
    ]
  }
}
