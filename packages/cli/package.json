{
  "name": "mcpscan",
  "version": "0.1.0",
  "description": "A security scanner for Model Context Protocol servers.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/mcpscan/mcpscan#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcpscan/mcpscan.git",
    "directory": "packages/cli"
  },
